{
  "manifest_version": 3,
  "name": "Twitch Chat on YouTube Live (Leopard)",
  "version": "1.0.0",
  "description": "Automatically opens or embeds Leopard's Twitch chat when watching Leopard's YouTube channel live stream.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "sidePanel",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.twitch.tv/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon48.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.twitch.tv/embed/*/chat*",
        "*://*.twitch.tv/popout/*/chat*"
      ],
      "js": [
        "twitch_content.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
